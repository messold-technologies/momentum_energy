# Server
PORT=3000
NODE_ENV=development

# Momentum Energy API - Sandbox
MOMENTUM_BASE_URL=https://ch2-preprod.api.momentumenergy.com.au/external-channels-exp-preprod
MOMENTUM_AUTH_URL=https://ch2-preprod.api.momentumenergy.com.au/oauth/token
MOMENTUM_CLIENT_ID=your_client_id_here
MOMENTUM_CLIENT_SECRET=your_client_secret_here

# CORS - comma separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Database (PostgreSQL - e.g. Neon, Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth (portal users - NOT Momentum API)
JWT_SECRET=your-secret-key-change-in-production
